{
  "name": "aitool-param-extractor",
  "version": "1.0.0",
  "description": "AITOOL 功率器件参数提取系统 - Electron 桌面应用",
  "main": "electron/main.js",
  "author": "GJW",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "electron:dev": "NODE_ENV=development electron electron/main.js",
    "electron:dev:win": "set NODE_ENV=development && electron electron/main.js",
    "electron:start": "npm run build:frontend && electron electron/main.js",
    "electron:build": "npm run build:frontend && electron-builder",
    "electron:build:win": "npm run build:frontend && electron-builder --win",
    "electron:build:mac": "npm run build:frontend && electron-builder --mac",
    "electron:build:linux": "npm run build:frontend && electron-builder --linux",
    "postinstall": "cd frontend && npm install",
    "start": "npm run electron:start"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {},
  "build": {
    "appId": "com.gjw.aitool",
    "productName": "AITOOL 参数提取系统",
    "copyright": "Copyright © 2024 GJW",
    "directories": {
      "output": "release",
      "buildResources": "electron/build"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/**/*",
      "!backend/venv/**/*",
      "!backend/**/__pycache__/**/*",
      "!backend/**/*.pyc",
      "!frontend/node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*", "!venv/**/*", "!**/__pycache__/**/*", "!**/*.pyc"]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "backend/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icons/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "rpm",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icons/icon.png",
      "category": "Office",
      "maintainer": "GJW",
      "vendor": "GJW",
      "synopsis": "功率器件参数提取系统",
      "description": "基于 AI 的功率器件数据手册参数提取工具"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AITOOL 参数提取系统",
      "installerIcon": "electron/icons/icon.ico",
      "uninstallerIcon": "electron/icons/icon.ico",
      "installerHeaderIcon": "electron/icons/icon.ico",
      "license": "LICENSE.txt",
      "artifactName": "AITOOL-Setup-${version}-${arch}.${ext}"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      },
      "artifactName": "AITOOL-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "AITOOL-Portable-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "gjw",
      "repo": "aitool-param-extractor"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
