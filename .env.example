# =====================================================
# 功率器件参数提取系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# =====================================================

# AI 配置（必填，至少配置一个）
AI_API_KEY=your-ai-api-key-here
AI_PROVIDER=deepseek
AI_MODEL=deepseek-chat
AI_API_BASE=https://api.deepseek.com/v1

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 数据库配置
DATABASE_URL=sqlite:///./data/params.db

# JWT 安全配置（生产环境务必修改）
SECRET_KEY=your-super-secret-key-change-this-in-production

# 性能配置
AI_TIMEOUT=60
AI_MAX_RETRIES=3
PDF_TIMEOUT=30
MAX_WORKERS=4
BATCH_SIZE=10
