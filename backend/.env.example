# AITOOL Backend Environment Variables

# 应用配置
DEBUG=true
HOST=0.0.0.0
PORT=8000

# 数据库配置（默认使用 SQLite）
# DATABASE_URL=sqlite:///./data/params.db
# PostgreSQL 示例:
# DATABASE_URL=postgresql://user:password@localhost/aitool

# JWT 安全配置（生产环境请务必修改！）
SECRET_KEY=your-super-secret-key-change-this-in-production

# AI 配置
AI_PROVIDER=deepseek
AI_MODEL=deepseek-chat
AI_API_KEY=your-api-key-here
AI_API_BASE=https://api.deepseek.com/v1
AI_TIMEOUT=60
AI_MAX_RETRIES=3

# 解析器配置
PDF_TIMEOUT=30
MAX_WORKERS=4
BATCH_SIZE=10
